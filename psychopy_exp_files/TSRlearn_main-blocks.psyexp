      <CodeComponent name="code_screen_out" plugin="None">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="// Get Pavlovia Survey responses&amp;#10;let resp = Demographics_Survey.getResponse();&amp;#10;console.log(&quot;Survey response:&quot;, resp);&amp;#10;&amp;#10;// If you used item &quot;Name&quot; fields in the Form:&amp;#10;const ageRaw     = resp[&quot;block_1/Geburtsdatum&quot;];&amp;#10;const eduRaw     = resp[&quot;block_1/Höchster Bildungsabschluss&quot;];&amp;#10;const germanRaw  = resp[&quot;block_1/Deutschsprachig&quot;];&amp;#10;const DrugRegRaw  = resp[&quot;block_1/Regelm_Dorgenkonsum&quot;];&amp;#10;const DrugCurRaw  = resp[&quot;block_1/Akt_Drogenkonsum&quot;];&amp;#10;const AlcCurRaw  = resp[&quot;block_1/Akt_Alkoholkonsum&quot;];&amp;#10;const MedsRaw  = resp[&quot;block_1/Medikamente&quot;];&amp;#10;const MenIllnessRaw  = resp[&quot;block_1/Psych_Erkrankung&quot;];&amp;#10;const SmokerRaw = resp[&quot;block_1/Raucher&quot;];&amp;#10;&amp;#10;console.log(ageRaw)&amp;#10;console.log(eduRaw)&amp;#10;console.log(germanRaw)&amp;#10;console.log(DrugRegRaw)&amp;#10;&amp;#10;&amp;#10;// ---------- normalize ----------&amp;#10;const norm = (x) =&gt; (x === undefined || x === null) ? &quot;&quot; : String(x).trim().toLowerCase();&amp;#10;&amp;#10;// Age &gt; 35&amp;#10;let age = Number(String(ageRaw).trim());&amp;#10;const excludeAge = Number.isFinite(age) &amp;&amp; age &gt; 35;&amp;#10;&amp;#10;// Education exclusions&amp;#10;const edu = norm(eduRaw);&amp;#10;const excludeEdu = (edu === &quot;Hauptschulabschluss&quot;&amp;#10;                 || edu === &quot;Realschulabschluss&quot;&amp;#10;                 || edu === &quot;Keine formalen Qualifikationen&quot;);&amp;#10;&amp;#10;// German fluency: exclude if &quot;Nein&quot;&amp;#10;const german = norm(germanRaw);&amp;#10;const excludeGerman = (german === &quot;nein&quot;);&amp;#10;&amp;#10;// drugs regular&amp;#10;const drugsreg = norm(DrugRegRaw);&amp;#10;const excludeDrugsReg = (drugsreg === &quot;other&quot;);&amp;#10;&amp;#10;// smokers &amp;#10;const smoking = norm(SmokerRaw);&amp;#10;const excludeSmokers = (smoking === &quot;ja&quot;);&amp;#10;&amp;#10;// drugs today&amp;#10;const drugstoday = norm(DrugCurRaw);&amp;#10;const excludeDrugsToday = (drugstoday === &quot;ja&quot;);&amp;#10;&amp;#10;// alc today&amp;#10;const alctoday = norm(AlcCurRaw);&amp;#10;const excludeAlcToday = (alctoday === &quot;ja&quot;);&amp;#10;&amp;#10;// meds current&amp;#10;const medscurrent = norm(MedsRaw);&amp;#10;const excludeMedsCurrent = (medscurrent === &quot;other&quot;);&amp;#10;&amp;#10;// ment illness &amp;#10;const MentIllness = norm(MenIllnessRaw);&amp;#10;const excludeMentIllness = (MentIllness === &quot;other&quot;);&amp;#10;&amp;#10;// Final flag&amp;#10;//window.screenedOut = (excludeAge || excludeEdu || excludeGerman || excludeDrugsReg&amp;#10;//|| excludeDrugsToday || excludeAlcToday || excludeSmokers); &amp;#10;&amp;#10;&amp;#10;// Flag for psychopy version&amp;#10;window.screenedOut = (excludeAge || excludeEdu || excludeGerman); &amp;#10;&amp;#10;// Save to data file&amp;#10;psychoJS.experiment.addData(&quot;screened_out&quot;, window.screenedOut ? 1 : 0);&amp;#10;psychoJS.experiment.addData(&quot;screenout_age&quot;, excludeAge ? 1 : 0);&amp;#10;psychoJS.experiment.addData(&quot;screenout_edu&quot;, excludeEdu ? 1 : 0);&amp;#10;psychoJS.experiment.addData(&quot;screenout_german&quot;, excludeGerman ? 1 : 0);&amp;#10;psychoJS.experiment.addData(&quot;screenout_drugsReg&quot;, excludeDrugsReg ? 1 : 0);&amp;#10;psychoJS.experiment.addData(&quot;screenout_drugsToday&quot;, excludeDrugsToday ? 1 : 0);&amp;#10;psychoJS.experiment.addData(&quot;screenout_AlcToday&quot;, excludeAlcToday ? 1 : 0);&amp;#10;psychoJS.experiment.addData(&quot;screenout_Smoking&quot;, excludeSmokers ? 1 : 0);&amp;#10;psychoJS.experiment.addData(&quot;answer_prescriptions_meds&quot;, medscurrent);&amp;#10;psychoJS.experiment.addData(&quot;answer_ment_illness&quot;, MentIllness);&amp;#10;&amp;#10;if (!window.screenedOut) {&amp;#10;  continueRoutine = false; // eligible -&gt; skip this routine instantly&amp;#10;}" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="JS" valType="str" updates="None" name="Code Type"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="if (window.screenedOut) {&amp;#10;  quitPsychoJS(&quot;Participant screened out.&quot;, false);&amp;#10;}" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="code_screen_out" valType="code" updates="None" name="name"/>
      </CodeComponent>

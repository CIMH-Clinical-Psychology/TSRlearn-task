      <CodeComponent name="set_trigger_retr_response_2" plugin="None">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="retr_trig_sent = false;&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="&amp;#10;retr_trig_sent = False&amp;#10;" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Auto-&gt;JS" valType="str" updates="None" name="Code Type"/>
        <Param val="RespTrig = trigger_dict[&quot;distance_retrieval_response&quot;]&amp;#10;&amp;#10;if not retr_trig_sent:&amp;#10;        if resp_4.keys:&amp;#10;            retr_trig_sent = True&amp;#10;&amp;#10;            send_trigger(RespTrig)&amp;#10;            core.wait(0.01) # need to wait a bit to avoid overlap with question trigger&amp;#10;&amp;#10;&amp;#10;           &amp;#10;&amp;#10;" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="RespTrig = trigger_dict[&quot;distance_retrieval_response&quot;];&amp;#10;if ((! retr_trig_sent)) {&amp;#10;    if (resp_4.keys) {&amp;#10;        retr_trig_sent = true;&amp;#10;        send_trigger(RespTrig);&amp;#10;        core.wait(0.01);&amp;#10;    }&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Each JS Frame"/>

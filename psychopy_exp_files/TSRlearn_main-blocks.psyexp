        <Param val="cond_file_learning = condFileLearning.format({&quot;participant_ID&quot;: expInfo[&quot;participant_ID&quot;]});&amp;#10;cond_file_retrieval = condFileRetrieval.format({&quot;participant_ID&quot;: expInfo[&quot;participant_ID&quot;]});&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>

        <Param val="&amp;#10;window.prc_fdbackClock = new util.Clock();&amp;#10;window.prc_fdbackClock.reset();" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="prc_fdbackClock = core.Clock()&amp;#10;prc_fdbackClock.reset()" valType="extendedCode" updates="constant" name="Begin Routine"/>

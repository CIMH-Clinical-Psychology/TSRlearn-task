        <Param val="polygon_7.setOpacity(0.0)&amp;#10;if chosenPos:&amp;#10;    polygon_7.setPos(chosenPos)&amp;#10;    polygon_7.setOpacity(1.0)&amp;#10;    polygon_7.setFillColor(polygonCol)&amp;#10;    polygon_7.setLineColor(polygonCol)" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="polygon_8.setOpacity(0.0)&amp;#10;if chosenPos:&amp;#10;    polygon_8.setPos(chosenPos)&amp;#10;    polygon_8.setOpacity(1.0)&amp;#10;    polygon_8.setFillColor(polygonCol)&amp;#10;    polygon_8.setLineColor(polygonCol)" valType="extendedCode" updates="constant" name="Begin Routine"/>

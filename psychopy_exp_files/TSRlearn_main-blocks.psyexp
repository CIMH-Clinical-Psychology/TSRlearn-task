        <Param val="if ((language === &quot;english&quot;)) {&amp;#10;    instruction_info.text = &quot;In the practice of the retrieval trials, you will get some background information on how the sequence of images is structured.\nThis will appear at the bottom.\n\nIn the main trials, there will be no additional information.\nYou should extract this information from the pairwise associations learned.\n\nPress any key to continue.&quot;;&amp;#10;}&amp;#10;if ((language === &quot;german&quot;)) {&amp;#10;    instruction_info.text = &quot;In der \u00dcbungsphase zu den Abrufdurchg\u00e4ngen erhalten Sie einige\nHintergrundinformationen dar\u00fcber, wie die Bildsequenz aufgebaut ist.\nDies wird unten am Bildschirm angezeigt. In der Hauptaufgabe gibt\nes keine zus\u00e4tzlichen Informationen. Sie sollten diese Informationen\naus den gelernten paarweisen Assoziationen extrahieren.\n\nDr\u00fccken Sie eine beliebige Taste, um weiterzumachen.&quot;;&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="&amp;#10;if language == &quot;english&quot;: &amp;#10;    instruction_info.text = (&amp;#10;    &quot;In the practice of the retrieval trials, you will get some background information on how the sequence of images is structured.\n&quot;&amp;#10;    &quot;This will appear at the bottom.\n\nIn the main trials, there will be no additional information.\n&quot; &amp;#10;    &quot;You should extract this information from the pairwise associations learned.\n\n&quot;&amp;#10;    &quot;Press any key to continue.&quot;&amp;#10;)  &amp;#10;if language == &quot;german&quot;: &amp;#10;    instruction_info.text = (&amp;#10;&quot;In der Übungsphase zu den Abrufdurchgängen erhalten Sie einige\n&quot;&amp;#10;&quot;Hintergrundinformationen darüber, wie die Bildsequenz aufgebaut ist.\n&quot;&amp;#10;&quot;Dies wird unten am Bildschirm angezeigt. In der Hauptaufgabe gibt\n&quot;&amp;#10;&quot;es keine zusätzlichen Informationen. Sie sollten diese Informationen\n&quot;&amp;#10;&quot;aus den gelernten paarweisen Assoziationen extrahieren.\n\n&quot;&amp;#10;&quot;Drücken Sie eine beliebige Taste, um weiterzumachen.&quot;&amp;#10;)  " valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Auto-&gt;JS" valType="str" updates="None" name="Code Type"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each Frame"/>

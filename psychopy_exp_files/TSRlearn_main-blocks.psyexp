      <CodeComponent name="ISIcode" plugin="None">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="# All the durations are in seconds&amp;#10;# Random ISI between 1 and 4. &amp;#10;minISI = 1&amp;#10;maxISI = 4&amp;#10;&amp;#10;# Task duration&amp;#10;length_of_task = 180&amp;#10;&amp;#10;# Feedback duration &amp;#10;feed = 0.5&amp;#10;&amp;#10;# A timer&amp;#10;timing = core.Clock()&amp;#10;&amp;#10;&amp;#10;" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="/* Syntax Error: Fix Python code */" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="# ISI is then set each routine&amp;#10;randISI = random.random() * (maxISI - minISI) + minISI&amp;#10;#randISI = random.uniform(minISI, max_ISI)&amp;#10;&amp;#10;# If it is the first trial&amp;#10;if PVT_trials.thisN == 0:&amp;#10;    overall_timer = core.Clock()&amp;#10;    realISI = 0&amp;#10;    &amp;#10;if PVT_trials.thisN &gt; 0:&amp;#10;    # We count the duration of the feedback as part of the ISI&amp;#10;    realISI = feed&amp;#10;&amp;#10;# A message when participant miss&amp;#10;message = 'You did not hit the button!'&amp;#10;message_german = 'Sie haben die LEERTASTE nicht gedrückt.'&amp;#10;&amp;#10;# Adding the ISI so it is saved in the datafile&amp;#10;thisExp.addData('ISI', randISI)" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Py" valType="str" updates="None" name="Code Type"/>
        <Param val="keys = dontrespond.getKeys(keyList=['space'], waitRelease=False)&amp;#10;keys = [key.name for key in keys]&amp;#10;&amp;#10;# Append True to list if a key is pressed, clear list if not&amp;#10;if &quot;space&quot; in keys:&amp;#10;     message = &quot;Too soon!&quot;&amp;#10;     message_german = &quot;Zu früh!&quot;&amp;#10;     continueRoutine = False&amp;#10;    " valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="True" valType="bool" updates="None" name="disabled"/>
        <Param val="ISIcode" valType="code" updates="None" name="name"/>
      </CodeComponent>
      <CodeComponent name="ISIcode_js" plugin="None">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="// All durations are in seconds&amp;#10;// Random ISI between 1 and 4&amp;#10;window.minISI = 1;&amp;#10;window.maxISI = 4;&amp;#10;&amp;#10;// Task duration&amp;#10;window.length_of_task = 180;&amp;#10;&amp;#10;// Feedback duration&amp;#10;window.feed = 0.5;&amp;#10;&amp;#10;// A timer&amp;#10;window.timing = new util.Clock();&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="window.too_early = false; &amp;#10;&amp;#10;// ISI is then set each routine&amp;#10;window.randISI = Math.random() * (maxISI - minISI) + minISI;&amp;#10;// (equivalent to random.uniform(minISI, maxISI))&amp;#10;&amp;#10;// If it is the first trial&amp;#10;if (PVT_trials.thisN === 0) {&amp;#10;  window.overall_timer = new util.Clock();&amp;#10;  window.realISI = 0;&amp;#10;}&amp;#10;&amp;#10;if (PVT_trials.thisN &gt; 0) {&amp;#10;  // We count the duration of the feedback as part of the ISI&amp;#10;  window.realISI = feed;&amp;#10;}&amp;#10;&amp;#10;// A message when participant miss&amp;#10;window.message = 'You did not hit the button!';&amp;#10;window.message_german = 'Sie haben die LEERTASTE nicht gedrückt.';&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="JS" valType="str" updates="None" name="Code Type"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="if (dontrespond.keys !== undefined &amp;&amp; dontrespond.keys !== null) {&amp;#10;    window.too_early = true;&amp;#10;    window.message = &quot;Too soon!&quot;;&amp;#10;    window.message_german = &quot;Zu früh!&quot;;&amp;#10;}" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>

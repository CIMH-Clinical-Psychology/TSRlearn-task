        <Param val="from psychopy import event  &amp;#10;&amp;#10;# which item sits where on THIS trial&amp;#10;pos2item = {}&amp;#10;pos2item[correct_pos] = prompt_prc&amp;#10;pos2item[dist01_pos]  = dist_01_prc&amp;#10;pos2item[dist02_pos]  = dist_02_prc&amp;#10;&amp;#10;# key -&gt; position mapping&amp;#10;key2pos = {&amp;#10;    left_key:   'left',&amp;#10;    right_key:  'right',&amp;#10;    center_key: 'center',&amp;#10;}&amp;#10;&amp;#10;event.clearEvents()&amp;#10;chosen_item = None&amp;#10;is_correct = None&amp;#10;&amp;#10;polygon.setOpacity(0.0)&amp;#10;polygon.setPos([0, 0])&amp;#10;&amp;#10;key_resp_2.keys = None&amp;#10;key_resp_2.rt = None&amp;#10;key_resp_2.clock.reset()&amp;#10;key_resp_2.start()" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="from psychopy import event  # if not already imported at the top&amp;#10;&amp;#10;# which item sits where on THIS trial&amp;#10;pos2item = {}&amp;#10;pos2item[correct_pos] = prompt_prc&amp;#10;pos2item[dist01_pos]  = dist_01_prc&amp;#10;pos2item[dist02_pos]  = dist_02_prc&amp;#10;&amp;#10;# key -&gt; position mapping&amp;#10;key2pos = {&amp;#10;    left_key:   'left',&amp;#10;    right_key:  'right',&amp;#10;    center_key: 'center',&amp;#10;}&amp;#10;&amp;#10;event.clearEvents()&amp;#10;chosen_item = None&amp;#10;is_correct = None&amp;#10;&amp;#10;polygon.setOpacity(0.0)&amp;#10;polygon.setPos([0, 0])&amp;#10;&amp;#10;key_resp_2.keys = None&amp;#10;key_resp_2.rt = None&amp;#10;" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Py" valType="str" updates="None" name="Code Type"/>
        <Param val="key_list = key_resp_2.getKeys(keyList=[left_key, right_key, center_key], waitRelease=False)&amp;#10;&amp;#10;if len(key_list) &gt; 0:&amp;#10;    pressed = key_list[0].name&amp;#10;    print(pressed)&amp;#10;    is_correct = (str(pressed) == str(correct_ans))&amp;#10;    print(correct_ans)&amp;#10;    print(&quot;is_correct:&quot;, is_correct)&amp;#10;    key_resp_2.corr = 1 if is_correct else 0" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="&amp;#10;key_list = key_resp_2.getKeys(keyList=[&quot;left&quot;, &quot;right&quot;, &quot;up&quot;], waitRelease=False)&amp;#10;&amp;#10;if len(key_list) &gt; 0:&amp;#10;    pressed = key_list[0].name&amp;#10;    print(pressed)&amp;#10;    is_correct = (str(pressed) == str(correct_ans))&amp;#10;    print(correct_ans)&amp;#10;    print(&quot;is_correct:&quot;, is_correct)&amp;#10;    key_resp_2.corr = 1 if is_correct else 0" valType="extendedCode" updates="constant" name="Each JS Frame"/>

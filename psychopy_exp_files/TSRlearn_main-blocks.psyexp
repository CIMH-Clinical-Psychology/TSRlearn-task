      <CodeComponent name="js_code_captcha" plugin="None">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="window.captchaVerified = false;&amp;#10;window.captchaReady = false;&amp;#10;window.captchaFailed = false;&amp;#10;window.scriptLoaded = false;&amp;#10;&amp;#10;// Callback on success&amp;#10;window.onCaptchaVerified = function(response) {&amp;#10;    window.captchaVerified = true;&amp;#10;};&amp;#10;&amp;#10;window.onRecaptchaLoad = function() {&amp;#10;    window.scriptLoaded = true;&amp;#10;};&amp;#10;&amp;#10;// Create container&amp;#10;var captchaContainer = document.createElement('div');&amp;#10;captchaContainer.id = 'recaptcha-container';&amp;#10;captchaContainer.style.position = 'absolute';&amp;#10;captchaContainer.style.top = '50%';&amp;#10;captchaContainer.style.left = '50%';&amp;#10;captchaContainer.style.transform = 'translate(-50%, -50%)';&amp;#10;captchaContainer.style.zIndex = '9999';&amp;#10;captchaContainer.innerHTML = '&lt;div id=&quot;recaptcha-widget&quot;&gt;&lt;/div&gt;';&amp;#10;document.body.appendChild(captchaContainer);&amp;#10;&amp;#10;// Load script&amp;#10;var recaptchaScript = document.createElement('script');&amp;#10;recaptchaScript.src = &quot;https://www.google.com/recaptcha/api.js?onload=onRecaptchaLoad&amp;render=explicit&quot;;&amp;#10;recaptchaScript.async = true;&amp;#10;recaptchaScript.defer = true;&amp;#10;recaptchaScript.onerror = function() {&amp;#10;    window.captchaFailed = true;&amp;#10;};&amp;#10;document.head.appendChild(recaptchaScript);&amp;#10;&amp;#10;window.captchaTimeout = new util.Clock();&amp;#10;window.renderAttempted = false;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="JS" valType="str" updates="None" name="Code Type"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="&amp;#10;&amp;#10;// Once script is loaded, try to render the widget&amp;#10;if (window.scriptLoaded &amp;&amp; !window.renderAttempted &amp;&amp; !window.captchaReady) {&amp;#10;    console.log(&quot;is working&quot;)&amp;#10;    var widget = document.getElementById('recaptcha-widget');&amp;#10;    if (widget) {&amp;#10;        try {&amp;#10;            grecaptcha.render(widget, {&amp;#10;                'sitekey': '6LexpmMsAAAAABa9C1T5vlsL4uNMUKJkPXJ6zq1x',&amp;#10;                'callback': window.onCaptchaVerified&amp;#10;            });&amp;#10;            window.captchaReady = true;&amp;#10;        } catch(e) {&amp;#10;            console.error('Render failed:', e);&amp;#10;            window.captchaFailed = true;&amp;#10;        }&amp;#10;        window.renderAttempted = true;&amp;#10;    }&amp;#10;}&amp;#10;&amp;#10;if (window.scriptLoaded &amp;&amp; !window.captchaReady &amp;&amp; !window.renderAttempted) {&amp;#10;    console.log('Script loaded, widget element exists:', !!document.getElementById('recaptcha-widget'));&amp;#10;    // ... rest of render code&amp;#10;}&amp;#10;if (window.captchaReady) {&amp;#10;    console.log('Widget rendered, waiting for user...');&amp;#10;}&amp;#10;window.onCaptchaVerified = function(response) {&amp;#10;    console.log('CAPTCHA CALLBACK FIRED');&amp;#10;    window.captchaVerified = true;&amp;#10;};&amp;#10;if (window.captchaVerified) {&amp;#10;    continueRoutine = false;&amp;#10;}" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="// Remove reCAPTCHA from page&amp;#10;// Remove container&amp;#10;var container = document.getElementById('recaptcha-container');&amp;#10;if (container) container.remove();&amp;#10;&amp;#10;// Remove reCAPTCHA iframes&amp;#10;var iframes = document.querySelectorAll('iframe[src*=&quot;recaptcha&quot;]');&amp;#10;iframes.forEach(function(iframe) { iframe.remove(); });&amp;#10;&amp;#10;// Remove the badge&amp;#10;var badge = document.querySelector('.grecaptcha-badge');&amp;#10;if (badge) badge.remove();&amp;#10;&amp;#10;// Store verification status in data&amp;#10;psychoJS.experiment.addData('captcha_verified', captchaVerified);&amp;#10;&amp;#10;" valType="extendedCode" updates="constant" name="End JS Routine"/>

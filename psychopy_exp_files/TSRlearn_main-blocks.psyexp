      <CodeComponent name="instruction_part9_text" plugin="None">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="&amp;#10;" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="if ((trial_type === 1)) {&amp;#10;    if ((language === &quot;english&quot;)) {&amp;#10;        instruction_part9.text = &quot;During the task, retrieval type 1 questions will be introduced by a keyword, instead of full instructions:\nCORRECT ORDER?\n\nPress RETURN to continue.&quot;;&amp;#10;    }&amp;#10;    if ((language === &quot;german&quot;)) {&amp;#10;        instruction_part9.text = &quot;W\u00e4hrend des Experiments werden Abruftyp-1-Fragen durch Stichworte angek\u00fcndigt, anstatt durch ausf\u00fchrliche Instruktionen:\nRICHTIGE REIHENFOLGE?\n\nDr\u00fccken Sie die EINGABETASTE, um weiterzumachen.&quot;;&amp;#10;    }&amp;#10;}&amp;#10;if ((trial_type === 2)) {&amp;#10;    if ((language === &quot;english&quot;)) {&amp;#10;        instruction_part9.text = &quot;During the task, retrieval type 2 questions will be introduced by a keyword, instead of full instructions:\nWHICH CLOSER?\n\nPress RETURN to continue.&quot;;&amp;#10;    }&amp;#10;    if ((language === &quot;german&quot;)) {&amp;#10;        instruction_part9.text = &quot;W\u00e4hrend des Experiments werden Abruftyp-2-Fragen durch Stichworte angek\u00fcndigt, anstatt durch ausf\u00fchrliche Instruktionen:\nWELCHES N\u00c4HER?\n\nDr\u00fccken Sie die EINGABETASTE, um weiterzumachen.&quot;;&amp;#10;    }&amp;#10;}&amp;#10;if ((trial_type === 3)) {&amp;#10;    if ((language === &quot;english&quot;)) {&amp;#10;        instruction_part9.text = &quot;During the task, retrieval type \u00a7 questions will be introduced by a keyword, instead of full instructions:\nHOW MANY IMAGES IN BETWEEN?\n\nPress RETURN to continue.&quot;;&amp;#10;    }&amp;#10;    if ((language === &quot;german&quot;)) {&amp;#10;        instruction_part9.text = &quot;W\u00e4hrend des Experiments werden Abruftyp-3-Fragen durch Stichworte angek\u00fcndigt, anstatt durch ausf\u00fchrliche Instruktionen:\nWIE VIELE BILDER DAZWISCHEN?\n\nDr\u00fccken Sie die EINGABETASTE, um weiterzumachen.&quot;;&amp;#10;    }&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="if trial_type == 1: &amp;#10;    if language == &quot;english&quot;: &amp;#10;        instruction_part9.text = (&amp;#10;        &quot;During the task, retrieval type 1 questions will be introduced by a keyword, instead of full instructions:\n&quot;&amp;#10;        &quot;CORRECT ORDER?\n\n&quot;&amp;#10;        &quot;Press RETURN to continue.&quot;&amp;#10;    )  &amp;#10;    if language == &quot;german&quot;: &amp;#10;        instruction_part9.text = (&amp;#10;    &quot;Während des Experiments werden Abruftyp-1-Fragen durch Stichworte angekündigt, anstatt durch ausführliche Instruktionen:\n&quot;&amp;#10;    &quot;RICHTIGE REIHENFOLGE?\n\n&quot;&amp;#10;    &quot;Drücken Sie die EINGABETASTE, um weiterzumachen.&quot;&amp;#10;    )&amp;#10;if trial_type == 2: &amp;#10;    if language == &quot;english&quot;: &amp;#10;        instruction_part9.text = (&amp;#10;        &quot;During the task, retrieval type 2 questions will be introduced by a keyword, instead of full instructions:\n&quot;&amp;#10;        &quot;WHICH CLOSER?\n\n&quot;&amp;#10;        &quot;Press RETURN to continue.&quot;&amp;#10;    )  &amp;#10;    if language == &quot;german&quot;: &amp;#10;        instruction_part9.text = (&amp;#10;    &quot;Während des Experiments werden Abruftyp-2-Fragen durch Stichworte angekündigt, anstatt durch ausführliche Instruktionen:\n&quot;&amp;#10;    &quot;WELCHES NÄHER?\n\n&quot;&amp;#10;    &quot;Drücken Sie die EINGABETASTE, um weiterzumachen.&quot;&amp;#10;    )&amp;#10;if trial_type == 3: &amp;#10;    if language == &quot;english&quot;: &amp;#10;        instruction_part9.text = (&amp;#10;        &quot;During the task, retrieval type § questions will be introduced by a keyword, instead of full instructions:\n&quot;&amp;#10;        &quot;HOW MANY IMAGES IN BETWEEN?\n\n&quot;&amp;#10;        &quot;Press RETURN to continue.&quot;&amp;#10;    )  &amp;#10;    if language == &quot;german&quot;: &amp;#10;        instruction_part9.text = (&amp;#10;    &quot;Während des Experiments werden Abruftyp-3-Fragen durch Stichworte angekündigt, anstatt durch ausführliche Instruktionen:\n&quot;&amp;#10;    &quot;WIE VIELE BILDER DAZWISCHEN?\n\n&quot;&amp;#10;    &quot;Drücken Sie die EINGABETASTE, um weiterzumachen.&quot;&amp;#10;    )" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Auto-&gt;JS" valType="str" updates="None" name="Code Type"/>
